    <string name="interval_label">基础间隔</string>
    <string name="interval_hint">例如 400</string>
    <string name="interval_help">单位毫秒。表示两次点击之间至少等待多久。1000 毫秒 = 1 秒，建议先从 300 到 800 之间尝试。</string>
    <string name="random_extra_label">随机附加延迟</string>
