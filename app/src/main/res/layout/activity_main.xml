<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/screen_title"
            android:textColor="#102A43"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/screen_subtitle"
            android:textColor="#486581"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/status_title"
            android:textColor="#102A43"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_permission_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#D9E2EC"
            android:lineSpacingExtra="4dp"
            android:padding="14dp"
            android:textColor="#102A43"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tv_selected_point"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#E6FFFA"
            android:padding="14dp"
            android:textColor="#0F766E"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_grant_overlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/grant_overlay" />

        <Button
            android:id="@+id/btn_grant_accessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/grant_accessibility" />

        <Button
            android:id="@+id/btn_pick_point"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/pick_point" />

        <Button
            android:id="@+id/btn_refresh_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/refresh_status" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/config_title"
            android:textColor="#102A43"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_interval_ms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#FFFFFF"
            android:ems="10"
            android:hint="@string/interval_hint"
            android:inputType="number"
            android:padding="12dp" />

        <EditText
            android:id="@+id/et_random_extra_ms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#FFFFFF"
            android:ems="10"
            android:hint="@string/random_extra_hint"
            android:inputType="number"
            android:padding="12dp" />

        <EditText
            android:id="@+id/et_repeat_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#FFFFFF"
            android:ems="10"
            android:hint="@string/repeat_count_hint"
            android:inputType="number"
            android:padding="12dp" />

        <Button
            android:id="@+id/btn_start"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/start_clicking" />

        <Button
            android:id="@+id/btn_stop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/stop_clicking" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#D9E2EC"
            android:padding="14dp"
            android:text="@string/usage_note"
            android:textColor="#334E68"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
